doctype html
html(lang="en")
	head
		title Projects - #{head.title}
		meta(charset="utf-8")
		meta(name="viewport" content="width=device-width,initial-scale=1,maximum-scale=2")
		meta(http-equiv="X-UA-Compatible" content="IE=edge,chrome=1")
		meta(name="renderer" content="webkit")
		meta(name="theme-color" content="#222325")
		meta(name="apple-mobile-web-app-status-bar-style" content="#222325")
		meta(name="msapplication-navbutton-color" content="#222325")
		link(rel="stylesheet" href="css/projects.css")
		meta(name="description" content=head.description)
		link(rel="icon" href="favicon.ico" type="image/x-icon")
		link(rel="shortcut icon" href="favicon.ico" type="image/x-icon")

	body
		main
			.content.content-projects
				#projects-container
					header
						a.back-button(href="index.html" aria-label="Back to home" title="Back to home")
							svg.back-icon(viewBox="0 0 24 24" width="24" height="24")
								path(d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z")
						h1(data-translate="name") #{main.name}
						h2 My Projects
						.view-toggle
							button#simple-view.active(title="Simple View")
								svg.icon(viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg")
									path(d="M128 128h768v85.333333H128z m0 341.333333h768v85.333334H128z m0 341.333334h768v85.333333H128z" fill="currentColor")
							button#detail-view(title="Detail View")
								svg.icon(viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg")
									path(d="M128 128h298.666667v298.666667H128zM469.333333 128h426.666667v298.666667H469.333333zM128 469.333333h298.666667v426.666667H128zM469.333333 469.333333h426.666667v426.666667H469.333333z" fill="currentColor")

					.timeline#timeline
						each project, index in projects
							.timeline-item(data-date=project.date data-index=index)
								.timeline-content
									if project.image
										.project-image
											img(src=project.image alt=project.title)
									.project-info
										h3.project-title= project.title
										.project-date= project.date
										.project-description= project.description
										.project-tags
											each tag in project.tags
												.tag= tag
										if project.python_tools && project.python_tools.length
											.project-python-tools
												h4 相关Python工具
												.python-tools-list
													each tool in project.python_tools
														.python-tool-item= tool

					.python-summary
						h2 Python 项目功能汇总报告
						
						.python-toolkit-overview
							.python-toolkit-card
								h3 🛠 Python工具集概览
								.python-stats
									.stat-item
										.stat-label 工具总数
										.stat-value #{python_toolkit_summary.total_tools}
									.stat-item
										.stat-label 核心技术
										.stat-value #{python_toolkit_summary.core_technologies.length}
									.stat-item
										.stat-label 分类数量
										.stat-value #{Object.keys(python_toolkit_summary.categories).length}
								
								h4 功能分类
								each category, name in python_toolkit_summary.categories
									.category-item
										.category-name= name
										.category-tools
											each tool in category
												.category-tool= tool
								
								h4 核心技术栈
								.tech-stack
									each tech in python_toolkit_summary.core_technologies
										.tech-tag= tech
								
								h4 部署状态
								.deployment-status
									each type, name in python_toolkit_summary.deployment_status
										.deployment-type
											.deployment-name= name
											.deployment-tools
												each tool in type
													.deployment-tool= tool
						
						.python-tools-library
							h3 🧰 Python工具库
							.tools-grid
								each tool in python_toolkit_summary.tools_details
									.tool-card(data-category=tool.category)
										.tool-header
											h4.tool-name= tool.name
											.tool-category= tool.category
										.tool-description= tool.description
										.tool-technical
											strong 技术方案：
											= tool.technical_solution
										.tool-dependencies
											strong 主要依赖：
											.dependency-tags
												each dep in tool.dependencies
													.dependency-tag= dep
										.tool-detailed
											strong 详细功能：
											= tool.detailed_description

		script(src="js/projects.js")
